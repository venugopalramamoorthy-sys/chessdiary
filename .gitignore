# Node (Playwright test tooling — not part of the app)
node_modules/
package.json
package-lock.json

# Stockfish server has its own git repo at chessdiary-stockfish
stockfish_server/

# Firebase service account keys — contain private keys, never commit
serviceAccount.json
serviceAccount.json.json
*serviceAccount*.json

# Firebase Android config — download from Firebase Console when cloning on a new machine
android/app/google-services.json

# Android signing — never commit keystores or key.properties
android/key.properties
android/upload-keystore.jks
*.jks
*.keystore

# Claude Code local settings
.claude/
